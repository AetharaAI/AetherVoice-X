{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::voice-raw-audio",
        "arn:aws:s3:::voice-raw-audio/*",
        "arn:aws:s3:::voice-normalized-audio",
        "arn:aws:s3:::voice-normalized-audio/*",
        "arn:aws:s3:::voice-transcripts",
        "arn:aws:s3:::voice-transcripts/*",
        "arn:aws:s3:::voice-tts-output",
        "arn:aws:s3:::voice-tts-output/*",
        "arn:aws:s3:::voice-debug-artifacts",
        "arn:aws:s3:::voice-debug-artifacts/*"
      ]
    }
  ]
}
