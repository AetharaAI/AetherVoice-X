HOST_BIND_IP=127.0.0.1
HF_TOKEN=
HOST_MODEL_ROOT=/mnt/aetherpro/models
HOST_HF_CACHE_ROOT=/mnt/aetherpro/hf-cache
HF_HOME=/hf-cache
HUGGINGFACE_HUB_CACHE=/hf-cache/hub
TRANSFORMERS_CACHE=/hf-cache/transformers
AETHER_MODEL_ROOT=/models
FASTER_WHISPER_MODEL_PATH=/models/audio/Systran/faster-whisper-large-v3
VOXTRAL_MODEL_PATH=/models/audio/mistralai/Voxtral-Mini-4B-Realtime-2602
# Set these when enabling the local or remote Voxtral realtime upstream.
# Example local sidecar values: http://voxtral:8000 and ws://voxtral:8000
VOXTRAL_HTTP_BASE_URL=http://voxtral:8000
VOXTRAL_WS_BASE_URL=ws://voxtral:8000
# Temporary dev/local default. Replace with a real shared key when locking down the sidecar.
VOXTRAL_API_KEY=EMPTY
# Legacy aliases still load if present:
# VOXTRAL_REALTIME_BASE_URL=
# VOXTRAL_REALTIME_WS_URL=
# VOXTRAL_REALTIME_API_KEY=
VOXTRAL_REALTIME_MODEL_NAME=mistralai/Voxtral-Mini-4B-Realtime-2602
VOXTRAL_REALTIME_TIMEOUT_SECONDS=90
VOXTRAL_STREAM_PARTIAL_WINDOW_MS=480
# Host GPU pin. Inside the container this still presents as cuda:0 when only one GPU is exposed.
VOXTRAL_GPU_IDS=2
VOXTRAL_CONTAINER_RUNTIME=nvidia
VOXTRAL_NVIDIA_DRIVER_CAPABILITIES=compute,utility
VOXTRAL_UPSTREAM_PORT=8000
VOXTRAL_HOST_PORT=8012
VOXTRAL_GPU_MEMORY_UTILIZATION=0.85
VOXTRAL_MAX_MODEL_LEN=8192
VOXTRAL_DISABLE_COMPILE_CACHE=1
VOXTRAL_VLLM_WORKER_MULTIPROC_METHOD=spawn
VOXTRAL_VLLM_LOGGING_LEVEL=INFO
VOXTRAL_UVICORN_LOG_LEVEL=info
QWEN3_ASR_MODEL_PATH=/models/audio/Qwen/Qwen3-ASR-1.7B
MOSS_MODEL_PATH=/models/audio/OpenMOSS-Team/MOSS-TTS-Realtime
MOSS_CODEC_MODEL_ID=OpenMOSS-Team/MOSS-Audio-Tokenizer
OPENMOSS_MODEL_ROOT=/mnt/aetherpro/models/audio/OpenMOSS-Team
# Optional local codec mount if you keep the tokenizer weights on block storage too.
# MOSS_CODEC_MODEL_PATH=/models/audio/OpenMOSS-Team/MOSS-Audio-Tokenizer
# Optional prompt/reference voice for realtime TTS.
# MOSS_PROMPT_AUDIO_PATH=/workspace/audio-tts/short-audio-test.wav
MOSS_REALTIME_BASE_URL=http://moss:8021
MOSS_REALTIME_TIMEOUT_SECONDS=180
MOSS_RUNTIME_PORT=8021
MOSS_HOST_PORT=8013
# Host GPU pin for realtime MOSS.
# Inside the container this should still use MOSS_REALTIME_DEVICE=cuda:0 when only this GPU is exposed.
MOSS_GPU_IDS=0
MOSS_CONTAINER_RUNTIME=nvidia
MOSS_NVIDIA_DRIVER_CAPABILITIES=compute,utility
MOSS_REALTIME_DEVICE=cuda:0
MOSS_REALTIME_ATTN_IMPLEMENTATION=auto
MOSS_REALTIME_MAX_LENGTH=3000
MOSS_REALTIME_SAMPLE_RATE=24000
MOSS_REALTIME_ENABLE_COMPILE=false
MOSS_REALTIME_PREFILL_TEXT_LEN=6
MOSS_REALTIME_DECODE_CHUNK_FRAMES=3
MOSS_REALTIME_DECODE_OVERLAP_FRAMES=0
MOSS_REALTIME_TEMPERATURE=0.8
MOSS_REALTIME_TOP_P=0.6
MOSS_REALTIME_TOP_K=30
MOSS_REALTIME_REPETITION_PENALTY=1.1
MOSS_REALTIME_REPETITION_WINDOW=50
MOSS_TTS_MODEL_PATH=/models/audio/OpenMOSS-Team/MOSS-TTS
MOSS_TTS_BASE_URL=http://moss-tts:8022
MOSS_TTS_TIMEOUT_SECONDS=240
MOSS_TTS_RUNTIME_PORT=8022
MOSS_TTS_HOST_PORT=8014
# Host GPU pin for the batch MOSS-TTS sidecar. Keep the OpenMOSS family aligned to the same host GPU plan unless intentionally changed.
# Inside-container device remains cuda:0.
MOSS_TTS_GPU_IDS=0
MOSS_TTS_CONTAINER_RUNTIME=nvidia
MOSS_TTS_NVIDIA_DRIVER_CAPABILITIES=compute,utility
MOSS_TTS_DEVICE=cuda:0
MOSS_TTS_ATTN_IMPLEMENTATION=auto
MOSS_TTSD_MODEL_PATH=/models/audio/OpenMOSS-Team/MOSS-TTSD-v1.0
MOSS_TTSD_BASE_URL=http://moss-ttsd:8023
MOSS_TTSD_TIMEOUT_SECONDS=240
MOSS_TTSD_RUNTIME_PORT=8023
MOSS_TTSD_HOST_PORT=8015
# Host GPU pin for the TTSD sidecar. Keep the OpenMOSS family aligned to the same host GPU plan unless intentionally changed.
# Inside-container device remains cuda:0.
MOSS_TTSD_GPU_IDS=0
MOSS_TTSD_CONTAINER_RUNTIME=nvidia
MOSS_TTSD_NVIDIA_DRIVER_CAPABILITIES=compute,utility
MOSS_TTSD_DEVICE=cuda:0
MOSS_TTSD_ATTN_IMPLEMENTATION=auto
MOSS_VOICE_GENERATOR_MODEL_PATH=/models/audio/OpenMOSS-Team/MOSS-VoiceGenerator
MOSS_VOICE_GENERATOR_BASE_URL=http://moss-voice-generator:8024
MOSS_VOICE_GENERATOR_TIMEOUT_SECONDS=240
MOSS_VOICE_GENERATOR_RUNTIME_PORT=8024
MOSS_VOICE_GENERATOR_HOST_PORT=8016
# Host GPU pin for the Voice Generator sidecar. Current working contract uses host GPU 3 as the shared studio/design lane.
# Chatterbox may also use GPU 3 opportunistically during generation, so avoid relying on both lanes concurrently.
# Inside-container device remains cuda:0.
MOSS_VOICE_GENERATOR_GPU_IDS=3
MOSS_VOICE_GENERATOR_CONTAINER_RUNTIME=nvidia
MOSS_VOICE_GENERATOR_NVIDIA_DRIVER_CAPABILITIES=compute,utility
MOSS_VOICE_GENERATOR_DEVICE=cuda:0
MOSS_VOICE_GENERATOR_ATTN_IMPLEMENTATION=auto
MOSS_SOUNDEFFECT_MODEL_PATH=/models/audio/OpenMOSS-Team/MOSS-SoundEffect
MOSS_SOUNDEFFECT_BASE_URL=http://moss-soundeffect:8025
MOSS_SOUNDEFFECT_TIMEOUT_SECONDS=240
MOSS_SOUNDEFFECT_RUNTIME_PORT=8025
MOSS_SOUNDEFFECT_HOST_PORT=8017
# Host GPU pin for the SoundEffect sidecar. Keep the OpenMOSS family aligned to the same host GPU plan unless intentionally changed.
# Inside-container device remains cuda:0.
MOSS_SOUNDEFFECT_GPU_IDS=0
MOSS_SOUNDEFFECT_CONTAINER_RUNTIME=nvidia
MOSS_SOUNDEFFECT_NVIDIA_DRIVER_CAPABILITIES=compute,utility
MOSS_SOUNDEFFECT_DEVICE=cuda:0
MOSS_SOUNDEFFECT_ATTN_IMPLEMENTATION=auto
PHI_MM_MODEL_PATH=/models/vision/microsoft/Phi-4-multimodal-instruct
CHATTERBOX_BASE_URL=https://tts.aetherpro.us
CHATTERBOX_DEFAULT_VOICE=Emily.wav

ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
# Host GPU pin for ASR. Inside the container, ASR should still run on cuda:0 unless you expose multiple GPUs.
ASR_GPU_IDS=1
ASR_CONTAINER_RUNTIME=nvidia
ASR_NVIDIA_DRIVER_CAPABILITIES=compute,utility

APP_ENV=development
LOG_LEVEL=INFO
AUTH_MODE=optional

JWT_SECRET=change_me
API_KEY_HEADER=X-API-Key

POSTGRES_URL=postgresql://voice:voice@postgres:5432/aether_voice
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_REGION=us-east-1
S3_BUCKET_RAW=voice-raw-audio
S3_BUCKET_NORMALIZED=voice-normalized-audio
S3_BUCKET_TRANSCRIPTS=voice-transcripts
S3_BUCKET_TTS=voice-tts-output
S3_BUCKET_DEBUG=voice-debug-artifacts
LOCAL_STORAGE_ROOT=/tmp/aether-storage

# Backend-held provider routing for TTS Studio. The frontend only receives provider labels and model IDs.
STUDIO_OPENAI_BASE_URL=https://api.openai.com/v1
STUDIO_OPENAI_API_KEY=
STUDIO_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
STUDIO_OPENROUTER_API_KEY=
STUDIO_LITELLM_BASE_URL=
STUDIO_LITELLM_API_KEY=
STUDIO_LITELLM_AUTH_HEADER=Authorization

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8010
ASR_HOST=0.0.0.0
ASR_PORT=8090
TTS_HOST=0.0.0.0
TTS_PORT=8091
FRONTEND_PORT=3010
GRAFANA_PORT=3001
COMPOSE_NGINX_PORT=8088

GATEWAY_ASR_BASE_URL=http://asr:8090
GATEWAY_TTS_BASE_URL=http://tts:8091
GATEWAY_ASR_WS_URL=ws://asr:8090
GATEWAY_TTS_WS_URL=ws://tts:8091
# Leave blank for production when the frontend is served behind nginx on the same origin.
# Set only for special direct-access or local dev cases.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
VITE_DEV_PROXY_TARGET=
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,asr.aetherpro.us,audio.aetherpro.us,studio.aetherpro.us
VITE_EXTERNAL_MODELS_JSON=[{"name":"phi-4-instruct","full_name":"phi-4-multimodal-instruct","base_url":"https://api.aetherpro.tech/v1","status":"live","provider":"vLLM via LiteLLM","capabilities":["text reasoning","audio understanding","image understanding"]},{"name":"qwen3.5-122","full_name":"Qwen3.5-122B-AWQ-4Bit","base_url":"https://api.blackboxaudio.tech/v1","status":"live","provider":"OpenAI-compatible inference gateway","capabilities":["text generation","image understanding","video input understanding"]}]

DEFAULT_BATCH_ASR_MODEL=faster_whisper
DEFAULT_STREAM_ASR_MODEL=voxtral-mini-4b-realtime-2602
DEFAULT_BATCH_TTS_MODEL=chatterbox
DEFAULT_STREAM_TTS_MODEL=moss_realtime

ENABLE_TTS_STUDIO=true

ENABLE_QWEN3_ASR=true
ENABLE_SENTINEL=true
ENABLE_PHI_OVERLAY=true
ENABLE_METRICS=true
ENABLE_SWAGGER=true

VOXTRAL_MODEL_ID=mistralai/Voxtral-Mini-4B-Realtime-2602
FASTER_WHISPER_MODEL_SIZE=small
QWEN3_ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B
SENTINEL_MODEL_ID=trishtan/voxtral-sentinel-4b
PHI_MM_MODEL_ID=microsoft/Phi-4-multimodal-instruct
MOSS_MODEL_ID=OpenMOSS-Team/MOSS-TTS-Realtime
MOSS_TTS_MODEL_ID=OpenMOSS-Team/MOSS-TTS
MOSS_TTSD_MODEL_ID=OpenMOSS-Team/MOSS-TTSD-v1.0
MOSS_VOICE_GENERATOR_MODEL_ID=OpenMOSS-Team/MOSS-VoiceGenerator
MOSS_SOUNDEFFECT_MODEL_ID=OpenMOSS-Team/MOSS-SoundEffect
